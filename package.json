    "@tanstack/react-query": "^5.80.7",
    "@trpc/client": "^11.4.3",
    "@trpc/react-query": "^11.4.3",
    "@trpc/server": "^11.4.3",
    "@trpc/tanstack-react-query": "^11.4.3",
    "@types/multer": "^2.1.0",
    "argon2": "^0.43.0",
    "atem-connection": "^3.9.0",
